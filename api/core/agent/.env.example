# Agent Service Configuration

# Core settings
SERVICE_NAME=agent
AGENT_PORT=8730
DEBUG=true

# AI Provider (qwen, gemini, bitexing, openai)
AI_PROVIDER=bitexing

# Bitexing Configuration (Proxy for Gemini/Banana)
BITEXING_API_KEY=sk-...
BITEXING_BASE_URL=https://bitexingai.com/v1

# Standard Provider Keys (Optional)
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...
DASHSCOPE_API_KEY=...
REMOVE_BG_API_KEY=...   # https://www.remove.bg/api — 50 free/month

# Infrastructure
REDIS_URL=redis://localhost:6379
ROUTER_URL=http://localhost:8600
