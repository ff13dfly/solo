# VPN configs (sensitive)
vpn/

# Logs
logs
*.log

# Dev mock listener real keys (deploy/mock/keys.env.example is the template)
deploy/mock/keys.env
deploy/mock/.ports

# Router's Ed25519 identity keypair — generated on first boot (handlers/keypair.js),
# must never be committed (it's the private key that signs every Router→service token)
api/router/.keypair
api/router/.password

# agent extract.test.js writes its report here every run — regenerated output, not a fixture
api/core/agent/tests/results/

# image-ps-gemini.test.js / internal/verify-integration.test.js write these dev-run outputs —
# regenerated on demand, not fixtures
api/core/agent/tests/samples/image/output_gemini_white_bg.*
api/core/agent/tests/samples/image/verify_output.jpg
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test
.env.production

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Mac OS
.DS_Store

# Custom log directory
api/debug/

# Build output
api/publish/
portal/publish/
client/publish/

# Release bundle staging (deploy/release-bundle.sh materializes solo.v*.js here
# from tags; reproducible, so never committed — upload to Release/object storage)
release/

# Orchestrator test-case generator output (tests/utils/generate_yaml.js writes these;
# hand-maintained fixtures are unit.yaml/boundary.yaml — generated_* are regenerable
# and read by no test, so they stay out of git)
api/core/orchestrator/tests/cases/generated_*.yaml

# Local Redis data
deploy/redis_data/

# storage service CAS filestore (UPLOAD_DIR default — api/apps/storage/config.js) — runtime data
uploads/

docs/private.md

# 产品愿景/灵感backlog — 保留在本地，不进仓库源真相面（易被误读为路线图/现状）
docs/idea/
