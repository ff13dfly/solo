# Copy to .env and fill in before running tests.

# Router (direct HTTP, not the SSL proxy the portals default to)
SOLO_ROUTER_URL=http://localhost:8600

# System portal admin credentials (used by global-setup to acquire auth state)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Operator portal test user (must be registered before running)
TEST_USER=testuser
TEST_PASSWORD=changeme
