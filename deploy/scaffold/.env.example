# Solo Core
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=<random-hex-32-bytes>        # init.sh 自动生成

# Router Identity
# init.sh 自动生成 .keypair 并填入下面两项，无需手动编辑。
# 手动轮换密钥时：重新生成 .keypair，同步更新 ROUTER_PUBLIC_KEY，重启所有服务。
SOLO_KEYPAIR_PATH=/path/to/project/.keypair
ROUTER_PUBLIC_KEY=<base58-public-key>

# Router 静态资源
# 新项目走 OSS，关闭 Router 的本地文件服务（避免它尝试解析不存在的 /uploads/assets）
ENABLE_STATIC_ASSETS=false

# Optional
# LOG_LEVEL=info
# NODE_ENV=production
