# Copy to .env and fill in before running:  cp .env.example .env

# Router endpoint (direct HTTP, NOT the SSL proxy the portal defaults to)
SOLO_ROUTER_URL=http://localhost:8600

# Where the operator portal is served:
#   - run.sh serves the built tarball on PORTAL_OPERATOR_PORT (default 3600)
#   - or run `cd portal/operator && npm run dev` and use the vite port (e.g. 5173)
OPERATOR_URL=http://localhost:3600

# Auth — pick ONE:
# (A) Easiest: a pre-seeded session token (e.g. deploy/seed-bots.js's solo-dev-admin).
#     Skips login entirely.
# SOLO_E2E_TOKEN=solo-dev-admin
#
# (B) A real operator user (register it first via the portal or user.register).
# TEST_USER=testuser
# TEST_PASSWORD=changeme
